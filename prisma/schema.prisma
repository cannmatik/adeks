generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                       String    @id @db.Uuid
  full_name                String?
  email                    String?   @unique
  phone                    String?
  adeks_member_no          String?   @unique
  role                     String    @default("customer")
  email_verified           Boolean   @default(false)
  verification_otp         String?
  verification_otp_expires DateTime? @db.Timestamptz(6)
  reset_otp                String?
  reset_otp_expires        DateTime? @db.Timestamptz(6)
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  reservations            Reservation[]
  conversations           Conversation[]
  messages                Message[]
  reservation_participants ReservationParticipant[]

  @@map("profiles")
}

model Room {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  color         String?
  display_order Int            @default(0)
  floor         String         @default("1")
  floor_col     Int            @default(0)
  floor_row     Int            @default(0)
  col_span      Int            @default(4)
  row_span      Int            @default(3)
  category      String?
  short_code    String?
  created_at    DateTime       @default(now()) @db.Timestamptz(6)

  tables Table[]

  @@map("rooms")
}

model Category {
  name        String @id
  label       String
  hourly_rate Decimal       @db.Decimal(10, 2)
  color       String        @default("#C0C0C0")
  description String?

  @@map("categories")
}

model FloorObject {
  id         String   @id @default(uuid()) @db.Uuid
  floor      String
  kind       String
  label      String?
  floor_col  Int      @default(0)
  floor_row  Int      @default(0)
  col_span   Int      @default(2)
  row_span   Int      @default(2)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("floor_objects")
}

model Table {
  id          String        @id @default(uuid()) @db.Uuid
  number      Int           @unique
  pc_id       String?
  category    String
  status      TableStatus   @default(AVAILABLE)
  notes       String?
  shape       String        @default("SQUARE")
  room_id     String?       @db.Uuid
  position_x  Int           @default(0)
  position_y  Int           @default(0)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)

  reservations      Reservation[]
  reservation_tables ReservationTable[]
  room               Room?            @relation(fields: [room_id], references: [id], onDelete: SetNull)

  @@map("tables")
}

model Reservation {
  id            String            @id @default(uuid()) @db.Uuid
  user_id       String            @db.Uuid
  table_id      String?           @db.Uuid
  start_time    DateTime          @db.Timestamptz(6)
  end_time      DateTime          @db.Timestamptz(6)
  status        ReservationStatus @default(REQUESTED)
  notes         String?
  admin_notes   String?
  contact_phone String?
  created_at    DateTime          @default(now()) @db.Timestamptz(6)
  updated_at    DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  user        Profile              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  table       Table?               @relation(fields: [table_id], references: [id], onDelete: Cascade)
  tables       ReservationTable[]
  participants ReservationParticipant[]
  conversation Conversation?

  @@index([table_id, start_time, end_time])
  @@index([user_id])
  @@map("reservations")
}


model Conversation {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String   @db.Uuid
  reservation_id  String?  @unique @db.Uuid
  last_message_at DateTime @default(now()) @db.Timestamptz(6)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  user        Profile      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  messages    Message[]

  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid()) @db.Uuid
  conversation_id String   @db.Uuid
  sender_id       String   @db.Uuid
  content         String
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender       Profile      @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@map("messages")
}

model ReservationTable {
  reservation_id String @db.Uuid
  table_id       String @db.Uuid

  reservation Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  table       Table       @relation(fields: [table_id], references: [id], onDelete: Cascade)

  @@id([reservation_id, table_id])
  @@map("reservation_tables")
}

model ReservationParticipant {
  reservation_id String @db.Uuid
  user_id        String @db.Uuid

  reservation Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  user        Profile     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([reservation_id, user_id])
  @@map("reservation_participants")
}



enum TableStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE

  @@map("table_status")
}

enum ReservationStatus {
  REQUESTED
  HOLD
  CONFIRMED
  CANCELLED
  COMPLETED

  @@map("reservation_status")
}

enum SessionKind {
  MEMBER
  ANONYMOUS

  @@map("session_kind")
}

model TableSession {
  id                   String       @id @default(uuid()) @db.Uuid
  table_id             String       @db.Uuid
  kind                 SessionKind
  user_id              String?      @db.Uuid
  anonymous_label      String?
  reservation_id       String?      @db.Uuid
  started_at           DateTime     @default(now()) @db.Timestamptz(6)
  ended_at             DateTime?    @db.Timestamptz(6)
  hourly_rate_snapshot Decimal?     @db.Decimal
  amount_charged       Decimal?     @db.Decimal
  notes                String?
  created_by           String?      @db.Uuid
  created_at           DateTime     @default(now()) @db.Timestamptz(6)

  @@map("table_sessions")
}

model TableStatusLog {
  id                  String       @id @default(uuid()) @db.Uuid
  table_id            String       @db.Uuid
  old_status          TableStatus?
  new_status          TableStatus
  changed_by          String?      @db.Uuid
  reason              String?
  related_session_id  String?      @db.Uuid
  created_at          DateTime     @default(now()) @db.Timestamptz(6)

  @@map("table_status_log")
}

model CafeSettings {
  id              String   @id @default("default")
  login_text      String   @default("Çalışma Saatleri: 07:30 - 02:00")
  footer_text     String   @default("Adeks İnternet Kafe Online Rezervasyon")
  open_time       String   @default("07:30")
  close_time      String   @default("02:00")
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("cafe_settings")
}
